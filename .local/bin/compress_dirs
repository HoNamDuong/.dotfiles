#!/bin/bash

if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <source_directory> <destination_directory>"
    exit 1
fi

SRC_DIR=$(realpath "$1")
DEST_DIR=$(realpath "$2")

if [ ! -d "$SRC_DIR" ]; then
    echo "Error: Source directory does not exist: $SRC_DIR"
    exit 1
fi

if [ ! -w "$DEST_DIR" ] && ! mkdir -p "$DEST_DIR"; then
    echo "Error: Cannot create or write to destination: $DEST_DIR"
    exit 1
fi

if ! command -v zip >/dev/null; then
    echo "Error: zip is not installed"
    exit 1
fi

cd "$SRC_DIR"

for dir in */; do
    if [ -d "$dir" ]; then
        zip -r "$DEST_DIR/${dir%/}.zip" "$dir" &&
            echo "Compressed: $dir -> $DEST_DIR/${dir%/}.zip"
    fi
done

cd -

echo "All folders compressed into $DEST_DIR"
