#!/bin/bash

mesg="Uptime: $(uptime -p | sed -e 's/up //g')"

lock='Lock'
logout='Logout'
suspend='Suspend'
hibernate="Hibernate"
reboot='Reboot'
poweroff='Poweroff'

get_choice() {
    if [ -f /usr/bin/rofi ]; then
        list_col='6'
        list_row='1'
        echo -e "$lock\n$logout\n$suspend\n$hibernate\n$reboot\n$poweroff" |
            rofi \
                -dmenu \
                -mesg "$mesg" \
                -i \
                -theme-str "
                    configuration {
                        show-icons: false;
                    }
                    window {
                        width: 1000px;
                    }
                    listview {
                        columns: $list_col;
                        lines: $list_row;
                        scrollbar: false;
                    }
                    inputbar {
                        enabled: false;
                    }
                    element-text {
                        horizontal-align: 0.5;
                    }"
    elif [ -f /usr/bin/dmenu ]; then
        echo -e "$lock\n$logout\n$suspend\n$hibernate\n$reboot\n$poweroff" |
            dmenu \
                -i \
                -p "$mesg" \
                -fn 'monospace-14' \
                -nf '#c5c8c6' \
                -nb '#1d1f21' \
                -sf '#c5c8c6' \
                -sb '#373B41'
    else
        exit 0
    fi
}

choice="$(get_choice)"

case ${choice} in
$lock)
    loginctl lock-session self
    ;;
$logout)
    loginctl kill-session self
    ;;
$suspend)
    /usr/bin/systemctl suspend
    ;;
$hibernate)
    /usr/bin/systemctl hibernate
    ;;
$reboot)
    /usr/bin/systemctl reboot
    ;;
$poweroff)
    /usr/bin/systemctl poweroff
    ;;
esac
